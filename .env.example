# ─────────────────────────────────────────────────────────────
# PSTAGEV1 — Variables d'environnement requises
# Copiez ce fichier en .env (jamais commité) et remplissez les valeurs.
# Sur Replit : ajoutez chaque variable dans l'onglet Secrets (cadenas).
# ─────────────────────────────────────────────────────────────

# ── Base de données (fournie automatiquement par Replit PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session Express (générer avec : openssl rand -hex 32)
SESSION_SECRET=your-random-hex-secret-here

# ── Stripe (https://dashboard.stripe.com/developers)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Vite prefix obligatoire pour exposer la clé au frontend
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Redis / Upstash (https://console.upstash.com)
# Format : redis://default:<password>@<host>:<port>
REDIS_URL=redis://default:password@host.upstash.io:6379

# ── Firebase Admin SDK (Firebase Console → Paramètres projet → Comptes de service)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# Collez la clé privée entre guillemets, les \n sont des sauts de ligne réels
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── CORS (laisser vide en dev, mettre l'URL de production en prod)
# FRONTEND_URL=https://votre-app.replit.app
